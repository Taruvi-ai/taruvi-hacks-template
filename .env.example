# Taruvi Configuration
# Copy this file to .env.local and fill in your values

# Base URL for Taruvi API (use HTTPS in production)
VITE_TARUVI_BASE_URL=

# API Key for authentication
VITE_TARUVI_API_KEY=

# Application slug identifier
VITE_TARUVI_APP_SLUG=

# Application title displayed in sidebar (optional, defaults to 'Taruvi')
VITE_TARUVI_APP_TITLE=CRM
